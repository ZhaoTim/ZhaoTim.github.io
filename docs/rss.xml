  const [count, setCount] = useState(0);&#13;
  useEffect(() =&gt; {&#13;
    if (count === 0) {&#13;
      const now = performance.now();&#13;
      while (performance.now() - now &lt; 200) {}&#13;
      setCount(10 + Math.random() * 200);&#13;
    }&#13;
  }, [count]);&#13;
&#13;
  return &lt;div onClick={() =&gt; setCount(0)}&gt;{count}&lt;/div&gt;;&#13;
}&#13;
&#13;
&#13;
